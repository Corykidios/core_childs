# Copy this file to .env and fill in your own values.
# .env is gitignored - never commit real secrets.

# MemoryPlugin (mp protocol)
MEMORY_PLUGIN_TOKEN=

# Model routing (used by both night.py and light.py)
WATCHER_LOCAL_MODEL=ollama/qwen3.5:9b
OLLAMA_API_BASE=http://localhost:11434

# Comma-separated cloud fallback chain, tried in order if local is
# unavailable (or always, for Light''s "smart" drafting calls).
WATCHER_CLOUD_MODELS=openrouter/deepseek/deepseek-chat,openrouter/meta-llama/llama-3.3-70b-instruct
OPENROUTER_API_KEY=
